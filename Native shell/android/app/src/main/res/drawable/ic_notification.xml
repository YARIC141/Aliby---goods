<?xml version="1.0" encoding="utf-8"?>
<!--
  Notification small icon — white italic "A" on transparent background.
  Android tints this automatically with the notification accent color.
  Path is a simplified italic-serif capital A that matches the Alliby brand.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Left stroke of A (italic, leaning right) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M 5.5,21
          L 8.2,21
          L 14.5,4
          L 11.8,4
          Z" />

    <!-- Right stroke of A -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M 11.0,4
          L 13.7,4
          L 20.0,21
          L 17.3,21
          Z" />

    <!-- Crossbar of A -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M 8.8,14.5
          L 17.0,14.5
          L 16.4,12.5
          L 9.4,12.5
          Z" />

</vector>
